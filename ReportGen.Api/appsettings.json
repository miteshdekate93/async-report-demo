{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection":  "Server=<YOUR_SERVER>;Database=ReportGenDb;Trusted_Connection=True;TrustServerCertificate=True;",
    "HangfireConnection": "Server=<YOUR_SERVER>;Database=ReportGenHangfire;Trusted_Connection=True;TrustServerCertificate=True;",
    "AzureStorage":       "UseDevelopmentStorage=true"
  },

  "JwtSettings": {
    "Secret":   "<REPLACE_WITH_32_CHAR_SECRET_IN_PRODUCTION>",
    "Issuer":   "ReportGen.Api",
    "Audience": "ReportGen.UI"
  },

  "Cors": {
    "AllowedOrigin": "http://localhost:4200"
  },

  "BlobStorage": {
    "LocalPath":          "/tmp/reports",
    "SimulationDelayMs":  10000,
    "AzureContainerName": "reports"
  }
}
